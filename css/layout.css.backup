/**
 * Layout System
 * Base layout utilities and containers
 */

.container {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 var(--space-5);
}

.stack > * + * {
  margin-top: var(--space-4);
}

.row {
  display: flex;
  gap: var(--space-4);
}

.row--center {
  align-items: center;
}

.grid {
  display: grid;
  gap: var(--space-4);
}

.grid--2 {
  grid-template-columns: 1fr 1fr;
}

.grid--3 {
  grid-template-columns: 1fr 1fr 1fr;
}

/* Skip Link for Accessibility */
.skip-link {
  position: absolute;
  top: -100px;
  left: var(--space-4);
  z-index: var(--z-modal);
  padding: var(--space-2) var(--space-4);
  background: var(--color-accent);
  color: var(--color-bg);
  text-decoration: none;
  border-radius: var(--radius-sm);
}

.skip-link:focus {
  top: var(--space-4);
}

/* Screen Reader Only */
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

/* Neural Interface Layout System */
[data-component="nlom-interface-app"] {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  position: relative;
  z-index: var(--z-base);
  background: transparent;
}

[data-component="neural-command-interface"] {
  position: sticky;
  top: 0;
  z-index: var(--z-overlay);
  background: transparent;
  backdrop-filter: blur(12px) saturate(1.2);
  border-bottom: 1px solid var(--glow-cyan-gentle);
  padding: var(--space-4) var(--space-6);
  /* Ensure atmospheric effects show through while maintaining glass effect */
  /* isolation: isolate; - Removed to prevent isolation of atmospheric effects */
}

[data-component="neural-flow-grid"] {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 var(--space-6);
}

/* Desktop-only layout - mobile media queries removed */

/* Protocol Status Left with Home Navigation */
[data-component="protocol-status-left"] {
  display: flex;
  align-items: center;
  justify-self: start;
  grid-column: 1;
}

[data-component="protocol-home-stack"] {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
}

[data-component="protocol-home-button"] {
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  transition: all var(--duration-base) var(--ease-organic);
  border-radius: var(--radius-full);
}

[data-component="protocol-home-button"]:focus {
  outline: 2px solid var(--color-accent);
  outline-offset: 4px;
}

[data-component="protocol-emblem"] {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--glass-bg-medium);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-full);
  box-shadow:
    0 4px 16px var(--shadow-neural-sm),
    inset 0 0 10px var(--glow-cyan-gentle);
  position: relative;
  overflow: hidden;
}

[data-component="protocol-emblem-icon"] {
  width: var(--space-5);
  height: var(--space-5);
  filter: drop-shadow(0 0 4px rgba(175, 238, 238, 0.4));
}

[data-component="protocol-text"] {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-1);
  font-size: var(--text-xs);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  text-align: center;
}

/* Header Balance Spacer */
[data-component="header-balance-spacer"] {
  justify-self: end;
  grid-column: 3;
  /* No fixed width needed - flexbox will handle centering */
}

.emblem-nexus .liquid-bubble {
  width: 64px;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--glass-bg-medium);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-full);
  position: relative;
  overflow: hidden;
  box-shadow:
    0 8px 32px var(--shadow-neural-md),
    inset 0 0 20px var(--glow-cyan-gentle);
}

.emblem-nexus .fluid-emblem {
  width: 32px;
  height: 32px;
  filter: drop-shadow(0 0 8px rgba(175, 238, 238, 0.4));
}

.protocol-whisper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-1);
  font-size: var(--text-xs);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.protocol-indicator {
  color: var(--color-text-muted);
  font-weight: 500;
}

.status-pulse {
  color: var(--color-accent);
  font-weight: 600;
  animation: status-glow 2s ease-in-out infinite alternate;
}

@keyframes status-glow {
  from {
    opacity: 0.7;
    text-shadow: 0 0 8px rgba(175, 238, 238, 0.4);
  }
  to {
    opacity: 1;
    text-shadow: 0 0 12px rgba(175, 238, 238, 0.6);
  }
}

/* Interface Identity */
[data-component="interface-identity"] {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
}

[data-component="interface-identity-center"] {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  justify-self: center;
  grid-column: 2; /* Ensure it stays in center column */
}

[data-component="interface-identity"] [data-component="liquid-text"],
[data-component="interface-title-display"] {
  pointer-events: none;
}

[data-component="interface-identity-center"] [data-component="liquid-text"],
[data-component="interface-title-display"] [data-component="liquid-text"] {
  display: flex;
  gap: var(--space-3);
  align-items: center;
}

[data-component="interface-identity"] [data-component="flowing-word"],
[data-component="interface-identity-center"] [data-component="flowing-word"] {
  font-size: var(--text-2xl);
  font-weight: 700;
  color: var(--color-accent);
  text-transform: uppercase;
  letter-spacing: 1px;
  position: relative;
}

[data-component="clearance-matrix"] {
  font-size: var(--text-sm);
  color: var(--color-warning);
  font-weight: 500;
  text-align: center;
  opacity: 0.9;
}

/* Search Nexus */
.search-nexus {
  position: relative;
  min-width: 280px;
}

.search-nexus .fluid-input-container {
  position: relative;
}

.search-nexus .liquid-input {
  width: 100%;
  padding: var(--space-3) var(--space-4);
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(175, 238, 238, 0.3);
  border-radius: var(--radius-lg);
  color: var(--color-text);
  font-size: var(--text-sm);
  backdrop-filter: blur(12px);
  transition: all var(--duration-base) var(--ease-organic);
}

.search-nexus .liquid-input:focus {
  outline: none;
  border-color: var(--color-accent);
  box-shadow: var(--shadow-neural-sm);
  background: rgba(0, 0, 0, 0.4);
}

.search-nexus .liquid-input::placeholder {
  color: var(--color-text-muted);
  font-style: italic;
}

/* Main Content Area */
[data-component="consciousness-ocean"] {
  flex: 1;
  position: relative;
  min-height: 0; /* Allow flex shrinking */
  padding: 0; /* Remove padding to fill screen */
  /* Full screen height for constellation map - removed height constraint to allow atmospheric effects */
  /* height: calc(100vh - 100px); - Removed to prevent clipping atmospheric effects */
  min-height: calc(100vh - 100px); /* Use min-height instead to maintain layout but allow extension */
  background: transparent;
}

/* Neural Navigation Footer */
.neural-navigation-anchor {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: var(--space-8);
  pointer-events: none;
  opacity: 0;
  visibility: hidden;
}

.navigation-essence {
  position: absolute;
  bottom: var(--space-2);
  left: 50%;
  transform: translateX(-50%);
  font-size: var(--text-xs);
  color: var(--color-text-dim);
  white-space: nowrap;
}

/* Neural particles system and legacy overrides removed - deprecated system disabled */

/* Mobile responsive adjustments removed - desktop-focused experience */
