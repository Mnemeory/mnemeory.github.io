/**
 * Standardized Atmospheric System
 * Seamless fog and glow effects with constellation-specific transitions
 * Replaces the banding-prone fluid-consciousness system
 */

/* === ATMOSPHERIC BASE LAYER === */

.atmospheric-base {
  position: fixed;
  top: -20vh;
  left: -20vw;
  right: -20vw;
  bottom: -20vh;
  width: 140vw;
  height: 140vh;
  pointer-events: none;
  z-index: -3;

}

/* === ATMOSPHERIC OVERLAY === */

.atmospheric-overlay {
  position: fixed;
  top: -20vh;
  left: -20vw;
  right: -20vw;
  bottom: -20vh;
  width: 140vw;
  height: 140vh;
  pointer-events: none;
  z-index: -2;
  opacity: 0.6;
  
  /* Gentle flowing fog effect */
  background:
    radial-gradient(
      ellipse 120% 80% at var(--atmo-x, 30%) var(--atmo-y, 40%),
      var(--glow-cyan-faint) 0%,
      transparent 75%
    ),
    radial-gradient(
      ellipse 100% 60% at var(--atmo-x2, 70%) var(--atmo-y2, 60%),
      var(--glow-pink-subtle) 0%,
      transparent 80%
    );
    
  /* Very slow, organic movement */
  animation: atmospheric-flow var(--duration-flow) ease-in-out infinite;
  
  /* Ensure full coverage without clipping */
  overflow: visible;
  will-change: transform;
}

/* === CONSTELLATION-SPECIFIC ATMOSPHERIC THEMES === */

/* Base atmospheric transition system */
.constellation-atmosphere {
  position: fixed;
  top: -20vh;
  left: -20vw;
  right: -20vw;
  bottom: -20vh;
  width: 140vw;
  height: 140vh;
  pointer-events: none;
  z-index: -1;
  opacity: 0;
  transition: opacity var(--duration-slower) var(--ease-neural);
  
  /* Seamless atmospheric fog base */
  background:
    radial-gradient(
      ellipse 150% 120% at 40% 30%,
      var(--constellation-primary-glow, var(--glow-cyan-gentle)) 0%,
      transparent 70%
    ),
    radial-gradient(
      ellipse 130% 100% at 60% 70%,
      var(--constellation-secondary-glow, var(--glow-pink-gentle)) 0%,
      transparent 75%
    ),
    radial-gradient(
      ellipse 180% 80% at 20% 80%,
      var(--constellation-accent-glow, var(--glow-cyan-faint)) 0%,
      transparent 80%
    );
    
  animation: constellation-atmospheric-flow var(--duration-flow-extended) ease-in-out infinite;
  
  /* Ensure full coverage without clipping */
  overflow: visible;
  will-change: transform;
}

/* Active constellation atmosphere */
.constellation-atmosphere.active {
  opacity: 0.5;
}

/* === CONSTELLATION-SPECIFIC THEMES === */

/* Gnarled Tree - Ancient Wisdom Atmosphere */
.constellation-atmosphere.tree-theme {
  --constellation-primary-glow: var(--constellation-tree-glow);
  --constellation-secondary-glow: var(--constellation-tree-bg);
  --constellation-accent-glow: var(--constellation-tree-glow);
}

/* Qu'Poxii - Love & Bond Atmosphere */
.constellation-atmosphere.bond-theme {
  --constellation-primary-glow: var(--constellation-bond-glow);
  --constellation-secondary-glow: var(--constellation-bond-bg);
  --constellation-accent-glow: var(--constellation-bond-glow);
}

/* Star Chanter - Wisdom Atmosphere */
.constellation-atmosphere.chant-theme {
  --constellation-primary-glow: var(--constellation-chant-glow);
  --constellation-secondary-glow: var(--constellation-chant-bg);
  --constellation-accent-glow: var(--constellation-chant-glow);
}

/* Hatching Egg - Growth Atmosphere */
.constellation-atmosphere.egg-theme {
  --constellation-primary-glow: var(--constellation-egg-glow);
  --constellation-secondary-glow: var(--constellation-egg-bg);
  --constellation-accent-glow: var(--constellation-egg-glow);
}

/* Void - Mystery Atmosphere */
.constellation-atmosphere.void-theme {
  --constellation-primary-glow: var(--constellation-void-glow);
  --constellation-secondary-glow: var(--constellation-void-bg);
  --constellation-accent-glow: var(--constellation-void-glow);
}

/* === SEAMLESS ANIMATIONS === */

@keyframes atmospheric-drift {
  0%, 100% {
    transform: scale(1) rotate(0deg);
    opacity: 0.8;
  }
  33% {
    transform: scale(1.02) rotate(0.5deg);
    opacity: 1;
  }
  66% {
    transform: scale(0.98) rotate(-0.3deg);
    opacity: 0.9;
  }
}

@keyframes atmospheric-flow {
  0%, 100% {
    --atmo-x: 30%;
    --atmo-y: 40%;
    --atmo-x2: 70%;
    --atmo-y2: 60%;
    transform: scale(1);
  }
  50% {
    --atmo-x: 60%;
    --atmo-y: 20%;
    --atmo-x2: 40%;
    --atmo-y2: 80%;
    transform: scale(1.01);
  }
}

@keyframes constellation-atmospheric-flow {
  0%, 100% {
    transform: scale(1) translateX(0) translateY(0);
    opacity: 0.4;
  }
  25% {
    transform: scale(1.01) translateX(1%) translateY(-0.5%);
    opacity: 0.5;
  }
  50% {
    transform: scale(0.99) translateX(-0.5%) translateY(1%);
    opacity: 0.6;
  }
  75% {
    transform: scale(1.005) translateX(0.5%) translateY(-0.5%);
    opacity: 0.45;
  }
}

/* === CONTENT OVERLAY ENHANCEMENT === */

.constellation-content-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
  
  /* Subtle constellation-specific content glow */
  background:
    radial-gradient(
      ellipse 60% 40% at 50% 20%,
      var(--constellation-accent-glow, var(--glow-cyan-ultra)) 0%,
      transparent 90%
    );
    
  opacity: 0;
  transition: opacity var(--duration-slower) var(--ease-neural);
}

[data-view*="-view"].active .constellation-content-overlay {
  opacity: 0.3;
}

/* === REDUCED MOTION SUPPORT === */

@media (prefers-reduced-motion: reduce) {
  .atmospheric-base,
  .atmospheric-overlay,
  .constellation-atmosphere {
    animation: none;
    transform: none;
  }
  
  .atmospheric-base {
    opacity: 0.6;
  }
  
  .atmospheric-overlay {
    opacity: 0.3;
  }
  
  .constellation-atmosphere.active {
    opacity: 0.2;
  }
}

/* === HIGH CONTRAST MODE === */

@media (prefers-contrast: high) {
  .atmospheric-base,
  .atmospheric-overlay {
    opacity: 0.1;
  }
  
  .constellation-atmosphere.active {
    opacity: 0.1;
  }
}
