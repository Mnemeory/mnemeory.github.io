/**
 * Citizen Management Interface Styles
 * For the Qu'Poxii constellation citizen management system
 *
 * REFACTORED TO USE DESIGN SYSTEM:
 * - Replaced hardcoded values with design tokens
 * - Uses existing utility classes (.neural-button, spacing tokens, etc.)
 * - Replaced non-existent CSS variables with proper design system variables
 * - Uses fluid typography and consistent spacing scale
 * - Maintains all original functionality while improving maintainability
 */

.citizen-management-container {
  min-height: 400px;
}

.constellation-intro {
  padding: var(--space-4);
  background: var(--constellation-bond-bg);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-6);
  border-left: var(--space-1) solid var(--color-kelpie);
}

.constellation-description {
  margin: 0;
  color: var(--color-text);
  font-style: italic;
}

.citizen-interface-wrapper {
  background: var(--bg-overlay-white-subtle);
  border-radius: var(--radius-xl);
  padding: var(--space-6);
  border: 1px solid var(--glass-border);
}

/* Citizen Management Main Interface */
.citizen-management {
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
  max-width: 100%;
}

.citizen-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-4);
  background: linear-gradient(
    135deg,
    var(--constellation-bond-bg) 0%,
    var(--constellation-bond-glow) 100%
  );
  border-radius: var(--radius-md);
  border: 1px solid var(--constellation-bond-primary);
}

.session-info h3 {
  margin: 0 0 var(--space-2) 0;
  color: var(--color-text);
  font-size: var(--text-lg);
  font-weight: 600;
}

.session-controls {
  display: flex;
  gap: var(--space-3);
}

/* Navigation */
.citizen-navigation {
  display: flex;
  gap: var(--space-2);
  padding: var(--space-2);
  background: var(--bg-overlay-interface);
  border-radius: var(--radius-md);
}

/* Navigation buttons - extends neural-button base styles */
.nav-btn.active {
  background: var(--constellation-bond-bg);
  border-color: var(--color-kelpie);
  color: var(--color-accent);
}

/* Content Area */
.citizen-content {
  min-height: 500px;
  padding: var(--space-4);
}

/* Files Panel */
.files-panel {
  background: var(--bg-overlay-white-subtle);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  border: 1px solid var(--glass-border);
  height: fit-content;
  max-height: 400px;
  overflow: hidden;
}

.files-panel h4 {
  margin: 0 0 var(--space-3) 0;
  color: var(--color-text);
  font-size: var(--text-lg);
  font-weight: 600;
}

/* Citizen Files Grid Layout for Thought Bubbles */
.citizen-files-bubbles {
  min-height: 120px;
  max-height: 300px;
  overflow-y: auto;
  overflow-x: hidden;
}

.citizen-files-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
  gap: var(--space-2);
  padding: var(--space-1);
}

/* Overview Grid */
.overview-grid {
  display: grid;
  grid-template-columns: 1fr 2fr 1fr;
  gap: var(--space-6);
  height: fit-content;
}

.stats-panel,
.citizens-panel,
.activity-panel {
  background: var(--bg-overlay-white-subtle);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
}

.stats-panel h4,
.citizens-panel h4,
.activity-panel h4 {
  margin: 0 0 var(--space-4) 0;
  color: var(--color-text);
  font-size: var(--text-base);
  font-weight: 600;
  border-bottom: 1px solid var(--glass-border);
  padding-bottom: var(--space-2);
}

/* Statistics */
.stats-grid {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.stat-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.stat-label {
  color: var(--color-text-muted);
  font-size: var(--text-sm);
}

.stat-value {
  color: var(--color-accent);
  font-weight: 600;
  font-size: var(--text-lg);
}

/* Citizens Panel */
.citizen-search {
  margin-bottom: var(--space-4);
}

.search-input {
  width: 100%;
  padding: var(--space-2);
  background: var(--bg-overlay-consciousness);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-sm);
  color: var(--color-text);
  font-size: var(--text-sm);
  font-family: var(--font-ui);
  transition: all var(--duration-fast) var(--ease-organic);
}

.search-input:focus {
  outline: none;
  border-color: var(--color-accent);
  box-shadow: var(--shadow-neural-sm);
}

.search-input::placeholder {
  color: var(--color-text-muted);
}

.citizens-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  max-height: 400px;
  overflow-y: auto;
}

/* Citizen Cards */
.citizen-card {
  background: var(--constellation-bond-bg);
  border: 1px solid var(--color-kelpie);
  border-radius: var(--radius-md);
  padding: var(--space-3);
  transition: all var(--duration-fast) var(--ease-organic);
}

.citizen-card:hover {
  background: var(--constellation-bond-glow);
  border-color: var(--color-kelpie);
  transform: translateY(-2px);
  box-shadow: var(--shadow-neural-sm);
}

.citizen-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-2);
}

.citizen-name {
  margin: 0;
  color: var(--color-text);
  font-size: var(--text-base);
  font-weight: 500;
}

.sci-badge {
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 600;
}

.sci-primary {
  background: var(--glass-bg-light);
  color: var(--color-accent);
  border: 1px solid var(--color-accent);
}

.sci-secondary {
  background: var(--constellation-egg-bg);
  color: var(--color-warning);
  border: 1px solid var(--color-warning);
}

.sci-tertiary {
  background: var(--glass-bg-cosmic);
  color: var(--color-error);
  border: 1px solid var(--color-error);
}

.citizen-card-info {
  margin-bottom: var(--space-3);
}

.citizen-status {
  margin: 0 0 var(--space-1) 0;
  color: var(--color-text-muted);
  font-size: var(--text-sm);
}

.citizen-location {
  margin: 0 0 var(--space-2) 0;
  color: var(--color-text-muted);
  font-size: var(--text-xs);
}

/* Behavioral Tags */
.citizen-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-1);
  margin-top: var(--space-2);
}

.tag-bubble {
  background: var(--constellation-bond-bg);
  color: var(--color-accent);
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 500;
  border: 1px solid var(--glass-border);
  text-transform: uppercase;
  letter-spacing: 0.3px;
}

.citizen-card-actions {
  display: flex;
  gap: var(--space-2);
  justify-content: flex-end;
}

/* Activity Log */
.activity-log {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  max-height: 300px;
  overflow-y: auto;
}

.log-entry {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
  padding: var(--space-2);
  background: var(--bg-overlay-interface);
  border-radius: var(--radius-sm);
  font-size: var(--text-sm);
}

.log-time {
  color: var(--color-text-muted);
  font-size: var(--text-xs);
}

.log-text {
  color: var(--color-text);
}

/* Forms */
.citizen-form {
  max-width: 800px;
  margin: 0 auto;
}

.citizen-form h4 {
  margin: 0 0 var(--space-6) 0;
  color: var(--color-text);
  font-size: var(--text-xl);
  text-align: center;
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-4);
  margin-bottom: var(--space-6);
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.form-group--full {
  grid-column: 1 / -1;
}

.form-group label {
  color: var(--color-text);
  font-size: var(--text-sm);
  font-weight: 500;
  font-family: var(--font-ui);
}

.form-group input,
.form-group select,
.form-group textarea {
  padding: var(--space-2);
  background: var(--bg-overlay-consciousness);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-sm);
  color: var(--color-text);
  font-size: var(--text-sm);
  font-family: var(--font-ui);
  transition: all var(--duration-fast) var(--ease-organic);
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  outline: none;
  border-color: var(--color-accent);
  box-shadow: var(--shadow-neural-sm);
}

.form-group small {
  color: var(--color-text-muted);
  font-size: var(--text-xs);
  font-style: italic;
}

.form-section {
  margin: var(--space-6) 0;
  padding-top: var(--space-4);
  border-top: 1px solid var(--glass-border);
}

.form-section h5 {
  margin: 0 0 var(--space-3) 0;
  color: var(--color-text);
  font-size: var(--text-base);
}

.form-actions {
  display: flex;
  gap: var(--space-4);
  justify-content: center;
  padding-top: var(--space-4);
  border-top: 1px solid var(--glass-border);
}

/* Empty States */
.empty-state {
  text-align: center;
  color: var(--color-text-muted);
  font-style: italic;
  padding: var(--space-8);
}

/* Session Gate Styles */
.session-gate {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 600px;
  padding: var(--space-6);
}

.session-gate-content {
  max-width: 600px;
  width: 100%;
  background: linear-gradient(
    135deg,
    var(--constellation-bond-bg) 0%,
    var(--constellation-bond-glow) 100%
  );
  border: 2px solid var(--color-kelpie);
  border-radius: var(--radius-xl);
  padding: var(--space-8);
  text-align: center;
  box-shadow: var(--shadow-neural-lg);
  position: relative;
  overflow: hidden;
}

.session-gate-content::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(
    circle at 30% 70%,
    var(--glass-glow) 0%,
    transparent 50%
  );
  pointer-events: none;
  opacity: 0.3;
  z-index: var(--z-base);
}

.session-gate-header {
  position: relative;
  z-index: var(--z-raised);
  margin-bottom: var(--space-6);
}

.gate-emblem {
  position: relative;
  width: 80px;
  height: 80px;
  margin: 0 auto var(--space-4);
}

.gate-emblem-icon {
  width: 100%;
  height: 100%;
  filter: drop-shadow(0 0 20px var(--color-kelpie));
  animation: float var(--duration-float) ease-in-out infinite;
}

.gate-ripples {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120px;
  height: 120px;
  border: 2px solid var(--color-kelpie);
  border-radius: 50%;
  opacity: 0.3;
  animation: ripple var(--duration-ripples) ease-out infinite;
}

.gate-ripples::before,
.gate-ripples::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border: 1px solid var(--color-kelpie);
  border-radius: 50%;
  opacity: 0.2;
}

.gate-ripples::before {
  width: 160px;
  height: 160px;
  animation: ripple var(--duration-ripples) ease-out infinite 1s;
}

.gate-ripples::after {
  width: 200px;
  height: 200px;
  animation: ripple var(--duration-ripples) ease-out infinite 2s;
}

@keyframes ripple {
  0% {
    transform: translate(-50%, -50%) scale(0.8);
    opacity: 0.6;
  }
  100% {
    transform: translate(-50%, -50%) scale(1.2);
    opacity: 0;
  }
}

@keyframes float {
  0%,
  100% {
    transform: translateY(0px);
  }
  50% {
    transform: translateY(-10px);
  }
}

.gate-title {
  margin: 0 0 var(--space-2) 0;
  color: var(--color-text);
  font-size: var(--text-2xl);
  font-weight: 700;
  text-shadow: 0 2px 10px var(--glass-glow);
}

.gate-subtitle {
  margin: 0 0 var(--space-6) 0;
  color: var(--color-accent);
  font-size: var(--text-lg);
  font-style: italic;
  font-weight: 500;
}

.session-gate-body {
  position: relative;
  z-index: var(--z-raised);
  margin-bottom: var(--space-6);
}

.gate-welcome h3 {
  margin: 0 0 var(--space-4) 0;
  color: var(--color-text);
  font-size: var(--text-xl);
  font-weight: 600;
}

.gate-welcome p {
  margin: 0 0 var(--space-6) 0;
  color: var(--color-text);
  font-size: var(--text-base);
  line-height: 1.6;
}

.gate-features {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-4);
  margin-bottom: var(--space-8);
  text-align: left;
}

.gate-feature {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
  padding: var(--space-3);
  background: var(--bg-overlay-white-subtle);
  border-radius: var(--radius-md);
  border: 1px solid var(--glass-border);
}

.feature-icon {
  font-size: var(--text-xl);
  flex-shrink: 0;
  margin-top: var(--space-1);
}

.feature-text h4 {
  margin: 0 0 var(--space-1) 0;
  color: var(--color-text);
  font-size: var(--text-base);
  font-weight: 600;
}

.feature-text p {
  margin: 0;
  color: var(--color-text-muted);
  font-size: var(--text-sm);
  line-height: 1.4;
}

.gate-session-start {
  background: var(--bg-overlay-consciousness);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-lg);
  padding: var(--space-6);
  margin-bottom: var(--space-6);
}

.session-requirement p {
  margin: 0 0 var(--space-2) 0;
  color: var(--color-text);
  font-size: var(--text-base);
  line-height: 1.5;
}

.session-requirement .session-note {
  color: var(--color-text-muted);
  font-size: var(--text-sm);
  font-style: italic;
  margin-bottom: var(--space-6);
}

/* Neural button large variant moved to unified system in utilities.css */

.session-gate-footer {
  position: relative;
  z-index: var(--z-raised);
  border-top: 1px solid var(--glass-border);
  padding-top: var(--space-4);
}

.gate-authority {
  margin: 0 0 var(--space-2) 0;
  color: var(--color-text-muted);
  font-size: var(--text-sm);
  font-weight: 500;
}

.gate-motto {
  margin: 0;
  color: var(--color-accent);
  font-size: var(--text-base);
  font-style: italic;
  font-weight: 500;
}

/* Responsive adjustments for session gate */
@media (max-width: 768px) {
  .session-gate {
    padding: var(--space-4);
    min-height: 500px;
  }

  .session-gate-content {
    padding: var(--space-6);
  }

  .gate-features {
    grid-template-columns: 1fr;
  }

  /* Neural button large responsive styles handled in utilities.css */
}
